/* ═══ MODAL ═══ */
.modal-ov{display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.82);backdrop-filter:blur(10px);align-items:center;justify-content:center;padding:20px}
.modal-ov.open{display:flex}
.modal-box{background:var(--navy);border:1px solid rgba(255,165,0,.25);border-radius:20px;padding:36px 32px;max-width:420px;width:100%;text-align:center;position:relative;animation:modalIn .3s cubic-bezier(.22,1,.36,1) both}
@keyframes modalIn{from{opacity:0;transform:scale(.9) translateY(18px)}to{opacity:1;transform:scale(1) translateY(0)}}
.modal-close{position:absolute;top:14px;right:14px;width:30px;height:30px;border-radius:50%;background:rgba(255,255,255,.07);border:none;cursor:pointer;color:rgba(255,255,255,.45);font-size:15px;display:flex;align-items:center;justify-content:center;transition:background .2s}
.modal-close:hover{background:rgba(255,255,255,.15)}
.modal-bar{height:3px;border-radius:100px;background:linear-gradient(90deg,rgba(255,165,0,.2),rgba(255,165,0,.9),rgba(255,165,0,.2));margin-bottom:20px;animation:barPulse 1.4s ease-in-out infinite}
@keyframes barPulse{0%,100%{transform:scaleX(.3);opacity:.5}50%{transform:scaleX(1);opacity:1}}
.modal-icon{width:52px;height:52px;border-radius:50%;background:rgba(255,165,0,.12);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;border:1px solid rgba(255,165,0,.25)}
.modal-icon svg{width:22px;height:22px;stroke:rgba(255,165,0,.85);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.modal-h{font-family:var(--g);font-size:20px;font-weight:900;color:#fff;margin-bottom:8px;letter-spacing:-.02em}
.modal-p{font-size:13px;font-weight:300;color:rgba(255,255,255,.45);line-height:1.78;margin-bottom:24px}
.modal-p strong{color:rgba(255,165,0,.85);font-weight:600}
.modal-btns{display:flex;gap:9px;flex-wrap:wrap;justify-content:center}
.modal-btn{display:inline-flex;align-items:center;gap:7px;padding:11px 20px;border-radius:100px;font-family:var(--g);font-size:12px;font-weight:700;text-decoration:none;transition:opacity .2s}
.modal-btn:hover{opacity:.85}
.mb-wa{background:#25D366;color:#fff}
.mb-mail{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.15);color:#fff}

